<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Proses Pembayaran"
        android:textColor="#0F172A"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvTotalDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tagihan: Rp 0"
        android:textColor="#0F172A"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Metode Pembayaran"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rgMetode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <RadioButton
            android:id="@+id/rbCash"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💵 Cash"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/rbEWallet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📱 E-Wallet"
            android:textSize="15sp" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Uang Dibayar"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/edtUangBayar"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:hint="Masukkan nominal..."
        android:inputType="numberDecimal"
        android:paddingStart="16dp"
        android:textSize="15sp"
        android:background="@drawable/bg_input"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvKembalianDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnHitungKembali"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_button_gradient"
        android:text="BAYAR SEKARANG"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="15sp" />

</LinearLayout>