<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RINGKASAN PEMBAYARAN"
        android:textColor="#94A3B8"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTotalDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Total: Rp 0"
        android:textColor="#0F172A"
        android:textSize="26sp"
        android:fontFamily="sans-serif-black" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="20dp"
        android:background="#F1F5F9" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MASUKKAN UANG TUNAI"
        android:textColor="#64748B"
        android:textSize="11sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edtUangBayar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_input"
        android:hint="Contoh: 50000"
        android:inputType="number"
        android:paddingStart="16dp"
        android:textSize="16sp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnHitungKembali"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_button_gradient"
        android:text="CEK KEMBALIAN"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="#DCFCE7"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KEMBALIAN"
            android:textColor="#16A34A"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvKembalianDialog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 0"
            android:textColor="#16A34A"
            android:textSize="24sp"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

</LinearLayout>