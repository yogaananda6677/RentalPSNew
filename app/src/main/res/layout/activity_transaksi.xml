<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="48dp"
        android:padding="12dp"
        android:background="@drawable/bg_circle_soft"
        android:backgroundTint="#FFFFFF"
        android:elevation="2dp"
        android:src="@drawable/ic_arrow_back_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:fontFamily="sans-serif-black"
        android:text="Transaksi Baru"
        android:textColor="#0F172A"
        android:textSize="28sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivBack" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UNIT PLAYSTATION"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold" />

<!--                <Spinner-->
<!--                    android:id="@+id/spPilihPs"-->
<!--                    android:layout_width="match_parent"-->
<!--                    android:layout_height="54dp"-->
<!--                    android:layout_marginTop="12dp"-->
<!--                    android:background="@drawable/bg_input" />-->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="#F1F5F9"
                    android:padding="12dp"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvNomorPs" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Pilih unit..." android:textColor="#0F172A" android:textStyle="bold" />
                    <TextView android:id="@+id/tvTipePs" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tipe: -" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvHargaPerJam" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Rp 0 / jam" android:textColor="#2563EB" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_white"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WAKTU SEWA"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtJamMulai"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_input"
                    android:drawableStart="@drawable/ic_access_time_24"
                    android:drawablePadding="12dp"
                    android:focusable="false"
                    android:hint="Jam Mulai"
                    android:paddingStart="16dp" />

                <Spinner
                    android:id="@+id/spDurasi"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_input" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnHitungSewa"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_button_gradient"
                    android:text="HITUNG ESTIMASI"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/tvJamSelesai" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Selesai: -" android:textColor="#64748B" />
                    <TextView android:id="@+id/tvSubtotalSewa" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textColor="#0F172A" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_white"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAMBAHAN PRODUK"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spProduk"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_input" />

                <EditText
                    android:id="@+id/edtQtyProduk"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="Jumlah (Qty)"
                    android:inputType="number"
                    android:paddingStart="16dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnTambahProduk"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_circle_soft"
                    android:text="+ Tambah Pesanan"
                    android:textColor="#475569"
                    android:textAllCaps="false"/>

                <TextView android:id="@+id/tvDetailProduk" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Belum ada pesanan tambahan" android:textSize="13sp" android:textColor="#94A3B8" />
                <TextView android:id="@+id/tvSubtotalProduk" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="end" android:text="Subtotal: Rp 0" android:textColor="#0F172A" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="40dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="TOTAL YANG HARUS DIBAYAR"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTotalSemua"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Rp 0"
                    android:textColor="#0F172A"
                    android:textSize="36sp"
                    android:fontFamily="sans-serif-black" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSimpanTransaksi"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_button_gradient"
                    android:text="PROSES SEKARANG"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>