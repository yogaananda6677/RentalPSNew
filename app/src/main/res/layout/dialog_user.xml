<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NAMA LENGKAP"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#64748B"
            android:letterSpacing="0.1"/>

        <EditText
            android:id="@+id/edtNamaUser"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_edittext_modern"
            android:hint="Contoh: Budi Santoso"
            android:paddingStart="16dp"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMAIL"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#64748B"
            android:letterSpacing="0.1"/>

        <EditText
            android:id="@+id/edtEmailUser"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_edittext_modern"
            android:hint="email@gmail.com"
            android:inputType="textEmailAddress"
            android:paddingStart="16dp"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOMOR HANDPHONE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#64748B"
            android:letterSpacing="0.1"/>

        <EditText
            android:id="@+id/edtNoHpUser"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_edittext_modern"
            android:hint="0812xxxx"
            android:inputType="phone"
            android:paddingStart="16dp"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PASSWORD"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#64748B"
            android:letterSpacing="0.1"/>

        <EditText
            android:id="@+id/edtPasswordUser"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_edittext_modern"
            android:hint="••••••••"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HAK AKSES (ROLE)"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#64748B"
            android:letterSpacing="0.1"/>

        <Spinner
            android:id="@+id/spRoleUser"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_edittext_modern" />

    </LinearLayout>
</ScrollView>