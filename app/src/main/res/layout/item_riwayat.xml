<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRiwayat"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_status"
            android:backgroundTint="#F0FDF4"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="Selesai"
            android:textColor="#16A34A"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvIdTransaksi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="TRX-001"
            android:textColor="#2563EB"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvStatus" />

        <TextView
            android:id="@+id/tvTanggal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10 April 2026"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/tvIdTransaksi"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/unitSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvTanggal">

            <FrameLayout
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@drawable/bg_circle_soft"
                android:backgroundTint="#EFF6FF">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_gamepad"
                    app:tint="#2563EB" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvNomorPs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unit PS A01"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvTipePs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Playstation 4"
                    android:textColor="#64748B"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvMetode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_status"
                android:backgroundTint="#F1F5F9"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Cash"
                android:textColor="#475569"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#F1F5F9"
            app:layout_constraintTop_toBottomOf="@id/unitSection" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/divider">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvJam"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="13:00 – 15:00"
                    android:textColor="#334155"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvDurasi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Durasi: 2 jam"
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="Rp 14.000"
                android:textColor="#0F172A"
                android:textSize="18sp"
                android:textStyle="bold" />
        </RelativeLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>